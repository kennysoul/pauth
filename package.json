{
  "name": "passkey-auth",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build:app": "vite build",
    "build": "npm run build:app",
    "dev": "npm run build:app && wrangler dev",
    "dev:app": "vite build --watch",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply passkey-auth-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply passkey-auth-db --remote",
    "types": "wrangler types"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.1.0",
    "@simplewebauthn/server": "^13.1.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^3.114.0"
  }
}
